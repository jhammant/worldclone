# LM Studio (local LLM stack — no API key needed)
WORLDCLONE_LLM_BASE_URL=http://localhost:1234/v1
WORLDCLONE_LLM_API_KEY=lm-studio
WORLDCLONE_LLM_MODEL=qwen/qwen3.6-27b
WORLDCLONE_LLM_PARALLEL=2

# Reasoning effort: none | low | medium | high
# Qwen 3.6 is a thinking model; "none" disables CoT for fast actor turns.
# Use "medium" for GM adjudication and questionnaire where reasoning helps.
WORLDCLONE_LLM_REASONING_DEFAULT=none

# Runtime guard (hours). Aborts simulation if projected total exceeds this.
WORLDCLONE_MAX_RUNTIME_HOURS=10

# Caching
WORLDCLONE_CACHE_DIR=./data/cache

# Exa.ai (one-time news fetch only — pipeline is air-gapped after that)
EXA_API_KEY=
